module tb_top(

    );
   reg clk;
    reg reset;

    Top my_cpu (
        .clk(clk),
        .reset(reset)
    );

    always #5 clk = ~clk;

    initial begin
        clk = 0;
        reset = 1;
        
        // 2. Initialize the Supervisor Stack Pointer (R6)
        my_cpu.cpu_datapath.lc3b_reg_file.registers[6] = 16'h3000;

        #20;
        reset = 0;

        #5000;
        $finish; 
    end
endmodule
